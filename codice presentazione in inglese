```{r}
#| label: setup
#| include: false

library(here)
library(tidyverse)
library(survey)
library(readxl)

# 1. FLEXIBLE CLEANING FUNCTION (CORRECTED)
clean_ehis <- function(df, year_label) {
  
  # Identify birthplace variable (BIRTHPLACE or BIRTHPLACE2)
  birth_var <- intersect(names(df), c("BIRTHPLACE2", "BIRTHPLACE"))[1]
  
  # PHQ-8 columns
  mh1_columns <- c("MH1A", "MH1B", "MH1C", "MH1D", "MH1E", "MH1F", "MH1G", "MH1H")
  
  df %>%
    # Select required columns
    select(WGT, RIP, any_of(c("UN1A", "UN1B")), all_of(mh1_columns), all_of(birth_var)) %>%
    # Convert to numeric
    mutate(across(everything(), ~suppressWarnings(as.numeric(as.character(.))))) %>%
    mutate(
      year = year_label,
      
      # ORIGIN HANDLING
      origin = case_when(
        .data[[birth_var]] == 10 ~ "Born in Italy",
        .data[[birth_var]] == 20 ~ "Born Abroad",
        TRUE ~ NA_character_ 
      ),
      
      # UNMET NEEDS
      unmet = case_when(
        UN1A == 1 | UN1B == 1 ~ 1,
        UN1A %in% c(2, 3) & UN1B %in% c(2, 3) ~ 0,
        TRUE ~ NA_real_
      )
    ) %>%
    # PHQ-8 REVERSE CODING
    mutate(across(all_of(mh1_columns), ~case_when(
      .x == 1 ~ 3,
      .x == 2 ~ 2,
      .x == 3 ~ 1,
      .x %in% c(4, 5) ~ 0,
      TRUE ~ NA_real_
    ))) %>%
    # Depression score
    mutate(depression_score = rowSums(select(., all_of(mh1_columns)), na.rm = FALSE)) %>%
    # Final cleaning
    filter(!is.na(origin), !is.na(unmet), !is.na(depression_score))
}

# 2. DATA LOADING
df2019 <- read_delim(here("EHIS_Microdata_2019.txt"), delim = "\t") %>% clean_ehis(2019)
df2015 <- read_excel(here("MICRODATA 2015 HEIS (1).xlsx")) %>% clean_ehis(2015)

# 3. MERGE AND SURVEY DESIGN
df_comparison <- bind_rows(df2015, df2019)
survey_design <- svydesign(ids = ~1, weights = ~WGT, data = df_comparison)
```
#Methodology

## The Data: EHIS Wave 2 and Wave 3
- **Data source:** European Health Interview Survey (EHIS), conducted by ISTAT.
- **Observation fields:**
    - **2015 (Wave 2):** Analysis of the pre-existing context.
    - **2019 (Wave 3):** Pre-pandemic context analysis.
- **Population:** Individuals over the age of 15 residing in Italy.
- **Representativeness:** Systematic use of the weighting variable 'WGT' to correct for sampling biases.

## Key Variables and Harmonization
- **Employee Variable (Target):** Waiver of Health Benefits ('UNMET_NEEDS').
- **Main Predictive Variable:** Mental Health Score **PHQ-8**.
    - Sum of 8 items on frequency of depressive symptoms (Scale 0-24).
- **Checks and Stratifications:**
    - Demographics: Gender, Age ('AGE_CLA75').
    - Socio-economic: Educational qualification, Income, Citizenship.
    - Territorials: Geographical distribution (Verification of the **Buffer Effect**).

# Descriptive Analysis: The Comparison 2015-2019

## Evolution of Care Giving Up
- The central question: has access to services improved or worsened?
- Comparison of weighted relative frequencies between 2015 and 2019.
- Analysis of the prevailing motivations:
    1. Economic reasons.
    2. Waiting lists.
    3. Distance from treatment centers.


